include "Universe.fbs";
include "Priority.fbs";
include "PerAddressPriority.fbs";
include "Transmit.fbs";
include "Level.fbs";
include "Address.fbs";

namespace mobilesacn.message;

table Blink {
    blink:bool;
}

union ChanCheckVal {
    universe:Universe,
    priority:Priority,
    perAddressPriority:PerAddressPriority,
    transmit:Transmit,
    level:Level,
    address:Address,
    blink:Blink,
}

table ChanCheck {
    val:ChanCheckVal (required);
}

root_type ChanCheck;
